OVERWRITE_SETTING_LDAP_Enable:true
OVERWRITE_SETTING_LDAP_Host:localhost
OVERWRITE_SETTING_LDAP_Reconnect:true
OVERWRITE_SETTING_LDAP_Port:389
OVERWRITE_SETTING_LDAP_BaseDN:ou=users,dc=yunohost,dc=org
OVERWRITE_SETTING_LDAP_Authentication:false
OVERWRITE_SETTING_LDAP_Username_Field:uid
OVERWRITE_SETTING_LDAP_Unique_Identifier_Field:uid
OVERWRITE_SETTING_LDAP_User_Search_Filter:(&(|(objectclass=posixAccount))(uid={{username}})(permission=cn=__APP__.main,ou=permission,dc=yunohost,dc=org))
OVERWRITE_SETTING_LDAP_User_Search_Scope:sub
OVERWRITE_SETTING_LDAP_User_Search_Field:uid
